# =========================
# 应用基础配置
# =========================

# 应用名称，会显示在页面标题、健康检查和日志中。
APP_NAME=具身机器人知识问答系统

# `make run` 会强制使用 development，`make run-prod` 会强制使用 production。
# 只有在你绕过 Makefile、直接运行 uvicorn 或自定义脚本时，这里的 APP_ENV 才会生效。
# 可选值通常为 development / production。
APP_ENV=development

# 服务监听地址，单机开发一般保持默认即可。
APP_HOST=0.0.0.0

# 服务监听端口，默认 8000。
APP_PORT=8000

# 生产模式下的 worker 数量；开发模式固定单进程。
APP_WORKERS=2

# 后端接口统一前缀，默认会拼成 `/api/v1/...`。
API_PREFIX=/api/v1

# 允许跨域的前端来源，`*` 表示全部放开。
CORS_ORIGINS=*

# 应用日志级别，常用 INFO / WARNING / ERROR / DEBUG。
LOG_LEVEL=INFO


# =========================
# DeepSeek 模型配置
# =========================

# DeepSeek 的 API Key，必填。
DEEPSEEK_API_KEY=your_deepseek_api_key

# DeepSeek 对话模型名称，默认 `deepseek-chat`。
DEEPSEEK_MODEL=deepseek-chat

# 生成温度，越高越发散，越低越稳定。
DEEPSEEK_TEMPERATURE=0.2

# 请求失败后的最大重试次数。
DEEPSEEK_MAX_RETRIES=2

# 单次模型请求超时时间，单位秒。
REQUEST_TIMEOUT_SECONDS=60


# =========================
# 知识库与检索配置
# =========================

# 知识库原始文档目录，默认读取 `data/knowledge/`。
KNOWLEDGE_BASE_DIR=data/knowledge

# 持久化向量库目录，Chroma 会把索引写到这里。
VECTOR_STORE_DIR=data/vector_store

# Chroma 集合名称，用来区分不同知识库索引。
VECTOR_STORE_COLLECTION_NAME=embodied_robot_knowledge

# 每次检索默认召回的文档块数量。
RETRIEVAL_K=4

# 召回分数阈值，越高越严格，越低越宽松。
RETRIEVAL_SCORE_THRESHOLD=0.18

# 文档切块大小，单位字符。
CHUNK_SIZE=650

# 相邻切块的重叠长度，避免上下文断裂。
CHUNK_OVERLAP=120

# 多轮问答时保留的历史轮数上限。
MAX_HISTORY_TURNS=6


# =========================
# 嵌入模型配置
# =========================

# 嵌入策略：
# `huggingface` 使用真实向量模型，效果更好；
# `local_hash` 为轻量本地兜底方案，适合离线演示或无模型环境。
EMBEDDING_STRATEGY=huggingface

# 向量维度；使用 `local_hash` 时会按这个维度生成向量。
EMBEDDING_DIMENSION=768

# HuggingFace 嵌入模型名称。
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# HuggingFace/Transformers 本地缓存目录。
EMBEDDING_CACHE_DIR=data/model_cache

# 嵌入模型运行设备，常用 `cpu` 或 `mps`/`cuda`。
EMBEDDING_DEVICE=cpu

# `true` 时只使用本地缓存，不访问 HuggingFace 网络。
EMBEDDING_HF_LOCAL_FILES_ONLY=false

# `true` 时 HuggingFace 初始化失败会自动回退到 `local_hash`。
EMBEDDING_FALLBACK_TO_LOCAL_HASH=true
